# Apimo API Configuration (Optional - defaults are provided in code)
# You can override these in Vercel's Environment Variables settings

APIMO_PROVIDER_ID=4567
APIMO_TOKEN=your-apimo-token
APIMO_AGENCY_ID=25311

# ============================================
# EMAIL CONFIGURATION
# ============================================

# The email address where property inquiries will be sent
CONTACT_EMAIL=your-email@squaremeter.com

# ============================================
# EMAIL SERVICE CONFIGURATION (Choose ONE)
# ============================================

# Option 1: Gmail (Recommended for quick setup)
# 1. Go to Google Account Settings
# 2. Security → 2-Step Verification → App passwords
# 3. Generate an app password for "Mail"
# 4. Use that password here (NOT your regular Gmail password)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Option 2: Custom SMTP (Any email provider)
# Works with Outlook, Yahoo, custom domains, etc.
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# Option 3: SendGrid (Professional service)
# Sign up at https://sendgrid.com
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ============================================
# TRANSLATION SERVICE (Optional)
# ============================================

# LibreTranslate API (Free, default)
TRANSLATE_API_URL=https://libretranslate.com/translate

# DeepL API (Better quality, requires API key)
DEEPL_API_KEY=your-deepl-api-key

# ============================================
# MAG ARTICLE VIEW COUNTS (Optional but required for public/shared counts)
# ============================================

# Supported option A: direct Redis connection string from Vercel Redis
KV_REDIS_URL=redis://default:password@host:port

# Supported option B: REST credentials exposed by Vercel KV / Upstash Redis
KV_REST_API_URL=https://your-kv-endpoint.upstash.io
KV_REST_API_TOKEN=your-kv-rest-token
