{
  "rewrites": [
    {
      "source": "/api/apimo/:path*",
      "destination": "/api/apimo"
    }
  ],
  "functions": {
    "api/google-reviews.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/send-property-inquiry.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/debug-careers.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/chatbot.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/wordpress.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/article-views.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/property-stats.js": {
      "maxDuration": 10,
      "memory": 512
    }
  },
  "env": {
    "NODE_ENV": "production",
    "CI": "false"
  }
}
